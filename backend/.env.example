# ============ AI 模型配置 ============

# 衣物识别模型（需要多模态/视觉能力）
# 方案一：通义千问 VL（推荐，国内快）
VISION_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL_API_KEY=sk-your-dashscope-api-key
VISION_MODEL_NAME=qwen-vl-plus

# 方案二：GPT-4o
# VISION_MODEL_BASE_URL=https://api.openai.com/v1
# VISION_MODEL_API_KEY=sk-your-openai-api-key
# VISION_MODEL_NAME=gpt-4o

# 搭配推荐模型（纯文本 LLM）
# 方案一：DeepSeek（推荐，便宜好用）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL_NAME=deepseek-chat

# 方案二：通义千问
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-api-key
# LLM_MODEL_NAME=qwen-plus

# ============ 服务配置 ============
HOST=0.0.0.0
PORT=8000
