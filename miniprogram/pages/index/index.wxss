.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* ======== Hero Banner ======== */
.hero-section {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB4B4 100%);
  padding: 48rpx 36rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-content {
  display: flex;
  align-items: center;
}

.hero-emoji {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.hero-text {
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ======== 上传按钮 ======== */
.upload-section {
  margin: -20rpx 32rpx 28rpx;
  position: relative;
  z-index: 10;
}

.upload-btn {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.15);
  transition: all 0.25s ease;
}

.upload-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.1);
}

.upload-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.upload-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.upload-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.upload-desc {
  font-size: 22rpx;
  color: #999999;
}

.upload-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ======== 衣橱区域 ======== */
.wardrobe-section {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
}

.section-count {
  font-size: 26rpx;
  color: #999999;
  background: rgba(0, 0, 0, 0.04);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

/* ======== 衣物网格 ======== */
.wardrobe-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

/* ======== 加载状态 ======== */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0F0F0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

/* ======== 底部操作区 ======== */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.recommend-btn {
  flex: 1;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
  border-radius: 999rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.25s ease;
}

.recommend-btn:active {
  transform: scale(0.96);
}

.recommend-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.recommend-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.recommend-text {
  font-size: 30rpx;
}

.select-btn {
  background: #FFFFFF;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
  border-radius: 999rpx;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.select-btn:active {
  background: rgba(255, 107, 107, 0.05);
}

.cancel-btn {
  background: #F5F5F5;
  color: #666666;
  border-radius: 999rpx;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部安全区占位 */
.bottom-safe {
  height: 160rpx;
}
