.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ======== 选择图片 ======== */
.choose-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.choose-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 40rpx;
}

.choose-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.choose-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.choose-desc {
  font-size: 26rpx;
  color: #999999;
}

.choose-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 48rpx;
}

.choose-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.25s ease;
}

.choose-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.camera-btn {
  border: 2rpx solid rgba(255, 107, 107, 0.2);
}

.album-btn {
  border: 2rpx solid rgba(78, 205, 196, 0.2);
}

.btn-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.btn-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

/* 拍照贴士 */
.choose-tips {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.6;
}

/* ======== AI 识别中 ======== */
.recognizing-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-image-wrapper {
  width: 100%;
  height: 500rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: #FFFFFF;
  margin-bottom: 32rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.recognizing-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.05);
}

/* 扫描线动画 */
.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #FF6B6B, transparent);
  animation: scan 2s ease-in-out infinite;
}

@keyframes scan {
  0% { top: 0; }
  50% { top: 100%; }
  100% { top: 0; }
}

.recognizing-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.recognizing-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0F0F0;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.recognizing-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.recognizing-sub {
  font-size: 24rpx;
  color: #999999;
}

/* ======== 识别结果 ======== */
.result-section {
  display: flex;
  flex-direction: column;
}

.result-image-wrapper {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-image {
  width: 100%;
  height: 100%;
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.result-label {
  font-size: 28rpx;
  color: #888888;
  min-width: 80rpx;
}

.result-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.color-value {
  display: flex;
  align-items: center;
}

.color-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.tag-value {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
  padding: 4rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.result-desc {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  margin-top: 16rpx;
  background: #FFF9F9;
  border-radius: 16rpx;
}

.desc-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.desc-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn-primary {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
  border-radius: 999rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.25s ease;
}

.action-btn-primary:active {
  transform: scale(0.97);
}

.action-btn-secondary {
  background: #FFFFFF;
  color: #666666;
  border-radius: 999rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid #EEEEEE;
}

.action-btn-secondary:active {
  background: #F9F9F9;
}

/* ======== 添加成功 ======== */
.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.success-emoji {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 64rpx;
}

.success-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
