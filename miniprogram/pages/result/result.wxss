.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ======== 加载动画 ======== */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-animation {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.loading-emoji {
  font-size: 80rpx;
  animation: wand 2s ease-in-out infinite;
}

@keyframes wand {
  0%, 100% { transform: rotate(-10deg) scale(1); }
  50% { transform: rotate(10deg) scale(1.1); }
}

.loading-particles {
  position: absolute;
  width: 100%;
  height: 100%;
}

.particle {
  position: absolute;
  font-size: 32rpx;
  animation: sparkle 1.5s ease-in-out infinite;
}

.particle:nth-child(1) {
  top: 0;
  right: 0;
}

.particle:nth-child(2) {
  bottom: 10rpx;
  left: 0;
}

.particle:nth-child(3) {
  top: 10rpx;
  left: 10rpx;
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1.2); }
}

.loading-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.loading-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.loading-progress {
  width: 400rpx;
  height: 8rpx;
  background: #F0F0F0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B, #FF8E8E, #FF6B6B);
  background-size: 200% 100%;
  border-radius: 4rpx;
  animation: progress 1.5s ease-in-out infinite;
}

@keyframes progress {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ======== 搭配结果 ======== */
.result-section {
  padding-bottom: 40rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.result-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* ======== 底部操作 ======== */
.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.refresh-btn {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #FFFFFF;
  border-radius: 999rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  transition: all 0.25s ease;
}

.refresh-btn:active {
  transform: scale(0.97);
}

.back-btn {
  background: #FFFFFF;
  color: #666666;
  border-radius: 999rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  border: 1rpx solid #EEEEEE;
}

.back-btn:active {
  background: #F9F9F9;
}

/* ======== 错误状态 ======== */
.error-section {
  padding-top: 80rpx;
}
