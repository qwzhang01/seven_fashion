.outfit-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.outfit-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.outfit-number {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-right: 16rpx;
}

.outfit-tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 10rpx;
}

.tag-primary {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

/* 衣物拼图 */
.outfit-items {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 24rpx 0;
  flex-wrap: wrap;
}

.outfit-item-thumb {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.thumb-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
  border: 2rpx solid #F0F0F0;
}

.thumb-label {
  font-size: 20rpx;
  color: #999999;
}

/* 搭配说明 */
.outfit-desc {
  padding: 20rpx 24rpx;
  background: #FFF9F9;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.7;
}

/* 搭配理由 */
.outfit-reason {
  margin-bottom: 20rpx;
}

.reason-text {
  font-size: 24rpx;
  color: #999999;
}

/* 操作按钮 */
.outfit-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.25s ease;
}

.save-btn {
  background: rgba(78, 205, 196, 0.1);
  color: #4ECDC4;
}

.save-btn:active {
  background: rgba(78, 205, 196, 0.2);
  transform: scale(0.96);
}

.like-btn {
  background: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.like-btn:active {
  background: rgba(255, 107, 107, 0.2);
  transform: scale(0.96);
}

.like-btn.liked {
  background: rgba(255, 107, 107, 0.15);
}

/* 全局动画 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up {
  animation: fadeInUp 0.5s ease-out both;
}
